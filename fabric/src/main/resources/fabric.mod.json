{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "license": "${mod_license}",
  "authors": [
    "${mod_authors}"
  ],
  "contact": {
    "sources": "${mod_sources_url}"
  },
  "icon": "assets/${mod_id}/icon.png",
  "environment": "client",
  "accessWidener": "increased-chat-height.accesswidener",
  "mixins": [
    "increased-chat-height.common.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader}",
    "minecraft": "~${minecraft_minor_version}",
    "java": ">=25"
  }
}
